# Gemini config used by router when it needs to reason/synthesize
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite-preview

# ResearchAgent will use GEMMA_GRADIO_URL when provided.
GEMMA_GRADIO_URL=https://your-gradio-space.gradio.live

# URLs cho sub-agents
MATH_AGENT_URL=http://127.0.0.1:9101
WEATHER_AGENT_URL=http://127.0.0.1:9102
RESEARCH_AGENT_URL=http://127.0.0.1:9103
ROUTER_AGENT_URL=http://127.0.0.1:9100

# Host va port
AGENT_HOST=127.0.0.1
MATH_AGENT_PORT=9101
WEATHER_AGENT_PORT=9102
RESEARCH_AGENT_PORT=9103
ROUTER_AGENT_PORT=9100

# Demo API
LOCAL_ROUTER_ENABLED=false
